          <select class="lbl" formControlName="CustomerId" (click)="bindcustomer()">
            <option class="lbl">none</option>
            <option class="lbl" *ngFor="let d of Customersnamedata index as i"
              [selected]="d._id===editreservedinefata[0].CustomerId" value="{{d._id}}">{{d.Name}}</option>
          </select>
        </div>
        <!-- [(ngModel)]="editreservedinefata[0].Name" -->
        <div class="form-group row">
          <div class="col"><label class="lbl" for="Name" id="Name"> Name :</label></div>
          <div class="col"><input class="lbl" type="text" [value]="editreservedinefata[0].Name"
              value="{{editreservedinefata[0].Name}}" formControlName="Name" id="Nametxt" /></div>
        </div>
        <!-- [(ngModel)]="editreservedinefata[0].MobileNo" -->
        <div class="form-group row">
          <div class="col"><label class="lbl" for="MobileNo" id="MobileNo"> MobileNo :</label></div>
          <div class="col"><input class="lbl" type="number" [value]="editreservedinefata[0].MobileNo" minlength="10"
              maxlength="20" formControlName="MobileNo" ngModel id="MobileNotxt" /></div>
        </div>
        <!-- [(ngModel)]="editreservedinefata[0].BookingAmount" -->
        <div class="form-group row">
          <div class="col"><label class="lbl" for="BookingAmount" id="BookingAmount"> BookingAmount :</label></div>
          <div class="col"><input class="lbl" type="number" [value]="editreservedinefata[0].BookingAmount"
              maxlength="10" formControlName="BookingAmount" ngModel id="BookingAmounttxt" /></div>
        </div>
        <!-- [(ngModel)]="editreservedinefata[0].Paymentstatus" -->
        <div class="form-group row">
          <div class="col"><label class="lbl" for="Paymentstatus" id="Paymentstatus"> Paymentstatus :</label></div>
          <div class="col"><input class="lbl" type="checkbox" [value]="editreservedinefata[0].Paymentstatus"
              formControlName="Paymentstatus" id="Paymentstatustxt" /></div>
        </div>
